{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		/* App project is type-check only — Vite handles the build */
		"composite": false,
		"declaration": false,
		"declarationMap": false,
		"noEmit": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

		"module": "ESNext",
		"moduleResolution": "Bundler",
		"paths": {
			"@/*": [
				"./src/*"
			]
		},
		"jsx": "react",
		"allowSyntheticDefaultImports": true
	},
	"include": [
		"src",
		"global.d.ts",
		"vite-env.d.ts"
	]
}
